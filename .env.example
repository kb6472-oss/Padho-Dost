# ─────────────────────────────────────────────────────────────
# PadhoDost — environment variables
# Copy to .env and fill in. Never commit .env itself.
# ─────────────────────────────────────────────────────────────

# Database (Supabase Postgres)
DATABASE_URL="postgresql://...:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://...:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# ── Analytics (W0) ───────────────────────────────────────────
# GA4 measurement id. Until this is set, NO analytics script is
# loaded and track() no-ops — the site ships zero extra bytes.
# Create at analytics.google.com → Admin → Data Streams → Web.
NEXT_PUBLIC_GA_ID=""

# ── AdSense ──────────────────────────────────────────────────
# Publisher id, e.g. "ca-pub-1234567890123456".
# Until this is set, no ad script loads and every AdSlot renders
# nothing — which is why ad revenue is currently structurally zero.
NEXT_PUBLIC_ADSENSE_CLIENT=""

# ── Daily current affairs cron ───────────────────────────────
NEWS_API_KEY=""
NEWS_API_PROVIDER="newsdata"   # gnews | newsdata
