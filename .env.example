# ─────────────────────────────────────────────────────────────
# PadhoDost — environment variables
# Copy to .env and fill in. Never commit .env itself.
# ─────────────────────────────────────────────────────────────

# Database (Supabase Postgres)
DATABASE_URL="postgresql://...:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://...:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# ── Analytics (W0) ───────────────────────────────────────────
# GA4 measurement id. Until this is set, NO analytics script is
# loaded and track() no-ops — the site ships zero extra bytes.
# Create at analytics.google.com → Admin → Data Streams → Web.
NEXT_PUBLIC_GA_ID=""

# ── AdSense ──────────────────────────────────────────────────
# Publisher id, e.g. "ca-pub-1234567890123456".
# Until this is set, no ad script loads and every AdSlot renders
# nothing — which is why ad revenue is currently structurally zero.
NEXT_PUBLIC_ADSENSE_CLIENT=""

# ── Daily current affairs cron ───────────────────────────────
# 1) fetch-current-affairs.ts pulls RAW headlines (source material only —
#    never published verbatim; that would be scraped content).
NEWS_API_KEY=""
NEWS_API_PROVIDER="newsdata"   # gnews | newsdata

# 2) build-ca-digest.ts turns them into ORIGINAL exam-format facts + a quiz.
#    Without this key the digest is never built and the CA pages fall back to
#    a noindex headline list.
ANTHROPIC_API_KEY=""
CA_DIGEST_MODEL=""             # optional; defaults to claude-opus-4-8

# Allow search engines to index current-affairs pages that HAVE a digest.
# Leave empty until you have reviewed a few days of real output — the pages
# stay noindex and out of the sitemap while this is unset.
CA_INDEXABLE=""                # set to "true" to enable indexing
